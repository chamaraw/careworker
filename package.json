  "private": true,
  "scripts": {
    "dev": "next dev -p 4000",
    "build": "next build",
    "start": "next start -p 4000",
    "clean": "rm -rf .next node_modules/.cache .turbo",
    "restart": "npm run clean && npm run build && npm run dev",
    "lint": "next lint",
    "db:seed": "npx prisma db seed",
